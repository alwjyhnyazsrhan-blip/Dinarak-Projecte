generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  fullName         String
  email            String             @unique
  phone            String?
  passwordHash     String
  referralCode     String             @unique
  referredById     String?
  role             String             @default("USER")
  balance          Float              @default(0)
  totalEarned      Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  referredBy       User?              @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]             @relation("UserReferrals")
  subscriptions    UserSubscription[]
  taskLogs         TaskLog[]
  transactions     WalletTransaction[]
  supportMessages  SupportMessage[]
}

model SubscriptionLevel {
  id              String             @id @default(cuid())
  name            String             @unique
  priceUsd        Float
  dailyTaskCount  Int
  dailyProfitUsd  Float
  benefits        String
  sortOrder       Int                @default(0)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  subscriptions   UserSubscription[]
  taskTemplates   TaskTemplate[]
}

model UserSubscription {
  id         String              @id @default(cuid())
  userId     String
  levelId    String
  status     String              @default("PENDING")
  startedAt  DateTime?
  endsAt     DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id])
  level      SubscriptionLevel   @relation(fields: [levelId], references: [id])
}

model TaskTemplate {
  id          String            @id @default(cuid())
  levelId     String
  title       String
  description String
  rewardUsd   Float
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  level       SubscriptionLevel @relation(fields: [levelId], references: [id])
  logs        TaskLog[]
}

model TaskLog {
  id             String       @id @default(cuid())
  userId         String
  taskTemplateId String
  completedOn    String
  rewardUsd      Float
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  taskTemplate   TaskTemplate @relation(fields: [taskTemplateId], references: [id])

  @@unique([userId, taskTemplateId, completedOn])
}

model WalletTransaction {
  id            String            @id @default(cuid())
  userId        String
  type          String
  status        String            @default("PENDING")
  currency      String
  network       String
  amount        Float
  txHash        String?
  walletAddress String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id])
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId     String?
  role      String
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
